# Server
PORT=8080
ENV=development
# After `go run ./cmd/server`, verify: `curl -s http://127.0.0.1:8080/health` ‚Üí 200
# and `curl -s -i http://127.0.0.1:8080/api/notification-preferences` ‚Üí 401 (not 404) if this API is running

# Browser origins allowed for CORS (comma-separated). Required in production when ENV=production.
# In development, if unset, localhost:5173 and :5174 are allowed by default.
# ALLOWED_ORIGINS=https://app.example.com,https://www.example.com

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret
# Required ‚Äî analyser service base URL (no default in code)
ANALYSER_URL=http://host.docker.internal:3000

# Database (direct connection to Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[password]@db.xxx.supabase.co:5432/postgres

# Claude API (optional when using analyser)
ANTHROPIC_API_KEY=sk-ant-...

# Razorpay (optional for development)
RAZORPAY_WEBHOOK_SECRET=whsec_...

# Encryption ‚Äî master key (KEK) for envelope encryption of health data.
#
# Development: set ENCRYPTION_KEY to a 64-char hex string (32 bytes).
#   Generate one: openssl rand -hex 32
# Production: leave ENCRYPTION_KEY unset and store the key in Supabase Vault instead:
#   SELECT vault.create_secret('$(openssl rand -hex 32)', 'vitalog-kek');
#
ENCRYPTION_KEY=
VAULT_SECRET_NAME=vitalog-kek
