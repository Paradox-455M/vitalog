# Supabase (required to run the app)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Go REST API base (optional)
# - Leave unset: relative /api/... (same origin — use with Vite dev proxy locally or a reverse proxy in production).
# - Set to your API origin when the SPA and API are on different hosts (e.g. staging/production split).
# VITE_API_URL=https://api.example.com

# Vite dev only: where the dev server proxies /api (not bundled; see vite.config.ts)
DEV_API_PROXY_TARGET=http://127.0.0.1:8080
